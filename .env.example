# ------------------------------------------------------------------------------
# Shopping Agent — environment configuration
# Copy to `.env` and adjust. Docker Compose and the backend both read these.
# ------------------------------------------------------------------------------

# ---- LLM provider -----------------------------------------------------------
# Which LLM backend to use: "ollama" (local-first, default) or "openai" (cloud).
LLM_PROVIDER=ollama
# Model id. For Ollama this is any pulled model (e.g. qwen2.5:7b, llama3.1:8b).
# For OpenAI use a model name like gpt-4o.
LLM_MODEL=qwen2.5-coder:14b
# Base URL of the Ollama server. In Docker Compose this is http://ollama:11434.
OLLAMA_BASE_URL=http://localhost:11434
# Unload the local model from memory after each response (frees RAM; makes the
# next request slower as the model reloads). Set true to release the LLM when idle.
OLLAMA_UNLOAD_AFTER_RESPONSE=false
# Only needed when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# ---- Payment (mock) ---------------------------------------------------------
# OTP the mock payment provider accepts. Swap the provider for a real PSP later.
MOCK_OTP=12345

# ---- Backend ----------------------------------------------------------------
PORT=8080
# Shared secret reserved for future API authentication (not enforced yet).
AGENT_SECRET=dev-secret-change-me
# Comma-separated allowed CORS origins for the web UI ("*" to allow any).
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ---------------------------------------------------------------
# Backend base URL the Next.js app calls (browser-visible).
NEXT_PUBLIC_API_URL=http://localhost:8080
